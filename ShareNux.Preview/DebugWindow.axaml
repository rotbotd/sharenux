<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ShareNux.Preview.DebugWindow"
        Title="ShareX - Debug log"
        Width="760" Height="541" MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterScreen">
    
    <DockPanel Margin="8">
        
        <!-- Button row at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Spacing="8">
            <!-- Startup path row -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Startup path:" Margin="0,0,0,0"/>
                <TextBlock x:Name="llRunningFrom" Text="/path/to/sharex" 
                           Foreground="CornflowerBlue" Cursor="Hand" Margin="0,0,0,0"/>
            </StackPanel>
            
            <!-- Buttons -->
            <WrapPanel Orientation="Horizontal">
                <Button x:Name="btnCopyAll" Content="Copy all" Width="152" Height="23" Margin="0,0,8,8"/>
                <Button x:Name="btnOpenLogFile" Content="Open log file..." Width="152" Height="23" Margin="0,0,8,8"/>
                <Button x:Name="btnLoadedAssemblies" Content="Loaded assemblies" Width="152" Height="23" Margin="0,0,8,8"/>
                <Button x:Name="btnUploadLog" Content="Upload log..." Width="152" Height="23" Margin="0,0,0,8"/>
            </WrapPanel>
        </StackPanel>
        
        <!-- Debug log textbox fills remaining space -->
        <TextBox x:Name="rtbDebug" 
                 IsReadOnly="True" 
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 FontFamily="Segoe UI"
                 FontSize="13"
                 Margin="0,0,0,8"/>
        
    </DockPanel>
</Window>
